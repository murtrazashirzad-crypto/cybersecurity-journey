## Task 6 — Clauses

```sql
-- DISTINCT: return unique values only
SELECT DISTINCT name FROM books;

-- GROUP BY: group rows sharing a value
SELECT name, COUNT(*) FROM books GROUP BY name;

-- ORDER BY: sort results (ASC = oldest/smallest first, DESC = newest/largest first)
SELECT * FROM books ORDER BY published_date ASC;
SELECT * FROM books ORDER BY published_date DESC;

-- HAVING: filter after GROUP BY (WHERE filters before grouping)
SELECT name, COUNT(*) FROM books GROUP BY name HAVING name LIKE '%hack%';

-- LIMIT: restrict number of rows returned
SELECT name FROM hacking_tools ORDER BY name ASC LIMIT 1;
```

